# Backend environment variables (example)
# Copy to backend/.env and fill with production values. Do NOT commit secrets.

# Database (Postgres/Supabase)
# Example format: postgresql://user:password@host:5432/postgres
DATABASE_URL=

# Environment
ENVIRONMENT=development
DEBUG=true

# Optional API keys
STEAM_API_KEY=
CS2SH_API_KEY=

# CSMarketAPI backfill keys (optional, 6 accounts for rate-limit spreading)
CSMARKETAPI_KEY_1=
CSMARKETAPI_ACCOUNT_1=
CSMARKETAPI_KEY_2=
CSMARKETAPI_ACCOUNT_2=
CSMARKETAPI_KEY_3=
CSMARKETAPI_ACCOUNT_3=
CSMARKETAPI_KEY_4=
CSMARKETAPI_ACCOUNT_4=
CSMARKETAPI_KEY_5=
CSMARKETAPI_ACCOUNT_5=
CSMARKETAPI_KEY_6=
CSMARKETAPI_ACCOUNT_6=

# Steam session cookies (from browser DevTools → Application → Cookies → steamcommunity.com)
# Required for /market/pricehistory/ endpoint (historical price data)
STEAM_SESSION_ID=
STEAM_LOGIN_SECURE=

# Server URL (used for Steam OpenID callback)
API_URL=http://localhost:8000

# Frontend origin
FRONTEND_URL=http://localhost:3000

# Replace with a secure random string in production
SECRET_KEY=replace-with-secure-random-value
